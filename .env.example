# Bybit API credentials
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here

# RSA alternative (leave blank if using HMAC)
BYBIT_API_PRIVATE_KEY_PATH=

# Environment: testnet | mainnet
BYBIT_ENV=testnet

# Safety caps
BYBIT_CAP_USD=500
BYBIT_CAP_USD_TOTAL_HOUR=2000
BYBIT_MAX_ORDERS_PER_HOUR=20

# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Suppress update prompts
BYBIT_CLI_NO_UPDATE_CHECK=0

# =============================================================
# LLM Agent (llm/agent_loop.py) — free tier providers
# =============================================================

# Active provider: groq | openrouter | gemini | ollama
LLM_PROVIDER=groq

# Model override (leave blank to use provider default)
# Groq fast:    llama-3.1-8b-instant
# Groq smart:   llama-3.3-70b-versatile
# OpenRouter:   meta-llama/llama-3.1-8b-instruct:free
# Gemini:       gemini-2.0-flash-lite
# Ollama local: llama3.2
LLM_MODEL=llama-3.1-8b-instant

# --- Groq (default, fastest free) ---
GROQ_API_KEY=gsk_...

# --- OpenRouter fallback ---
OPENROUTER_API_KEY=

# --- Google Gemini fallback ---
GEMINI_API_KEY=

# --- Ollama local (no key needed) ---
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2

# Default symbol for LLM actions when not specified
DEFAULT_SYMBOL=BTCUSDT
