# Bybit API credentials
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here

# RSA alternative (leave blank if using HMAC)
BYBIT_API_PRIVATE_KEY_PATH=

# Environment: testnet | mainnet
BYBIT_ENV=testnet

# Safety caps
BYBIT_CAP_USD=500
BYBIT_CAP_USD_TOTAL_HOUR=2000
BYBIT_MAX_ORDERS_PER_HOUR=20

# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Suppress update prompts
BYBIT_CLI_NO_UPDATE_CHECK=0

# =============================================================
# LLM Agent (llm/agent_loop.py)
# =============================================================

# Active provider: groq | openrouter | gemini | ollama
LLM_PROVIDER=groq

# Model override
# Groq fast:    llama-3.1-8b-instant
# Groq smart:   llama-3.3-70b-versatile
# OpenRouter:   meta-llama/llama-3.1-8b-instruct:free
# Gemini:       gemini-2.0-flash-lite
# Ollama local: llama3.2
LLM_MODEL=llama-3.1-8b-instant

# Auto-fallback chain on rate-limit/error
LLM_FALLBACK_CHAIN=groq,openrouter,gemini

# Groq (default, fastest free)
GROQ_API_KEY=gsk_...

# OpenRouter fallback
OPENROUTER_API_KEY=

# Google Gemini fallback
GEMINI_API_KEY=

# Ollama local
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2

# =============================================================
# Multi-symbol scanner (llm/agent_loop.py)
# =============================================================

# Comma-separated symbols to scan each tick
WATCHLIST=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,XRPUSDT,DOGEUSDT,AVAXUSDT,ADAUSDT,LINKUSDT,DOTUSDT

# How many top opportunities to send to LLM (1-5 recommended)
SCAN_TOP_N=3

# Default symbol fallback
DEFAULT_SYMBOL=BTCUSDT

# Regime detection thresholds (optional tuning)
TREND_THRESH=0.003
VOL_THRESH_HIGH=0.02
VOL_THRESH_LOW=0.008

# Paid providers (optional)
TOGETHER_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=
