# Bybit API credentials
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here
BYBIT_API_PRIVATE_KEY_PATH=
BYBIT_ENV=testnet

# Safety caps
BYBIT_CAP_USD=500
BYBIT_CAP_USD_TOTAL_HOUR=2000
BYBIT_MAX_ORDERS_PER_HOUR=20

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
BYBIT_CLI_NO_UPDATE_CHECK=0

# =============================================================
# LLM Agent
# =============================================================
LLM_PROVIDER=groq
LLM_MODEL=llama-3.1-8b-instant
LLM_FALLBACK_CHAIN=groq,openrouter,gemini
GROQ_API_KEY=gsk_...
OPENROUTER_API_KEY=
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2

# =============================================================
# Dynamic Watchlist (llm/watchlist.py)
# =============================================================

# linear | spot | inverse
WATCHLIST_CATEGORY=linear

# Max symbols to keep after scoring
WATCHLIST_TOP_N=15

# Minimum 24h volume in USDT (liquidity floor)
# 10M = default for liquid futures; lower for spot (e.g. 1000000)
WATCHLIST_MIN_VOL_USD=10000000

# Maximum bid-ask spread % (execution quality gate)
WATCHLIST_MAX_SPREAD_PCT=0.1

# Minimum absolute 24h price change % (something must be moving)
WATCHLIST_MIN_CHANGE_PCT=0.5

# Always include these symbols even if below criteria
WATCHLIST_ALWAYS_INCLUDE=BTCUSDT,ETHUSDT

# Cache TTL in seconds (avoid re-fetching on every tick)
WATCHLIST_CACHE_TTL_SEC=300

# How many ticks between forced watchlist refreshes
WATCHLIST_REFRESH_TICKS=4

# How many top opportunities to send to LLM per tick
SCAN_TOP_N=3

# Default symbol fallback
DEFAULT_SYMBOL=BTCUSDT

# Regime thresholds
TREND_THRESH=0.003
VOL_THRESH_HIGH=0.02
VOL_THRESH_LOW=0.008

# Paid providers (optional)
TOGETHER_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=
