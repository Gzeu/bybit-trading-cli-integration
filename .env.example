# Bybit API credentials
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here
BYBIT_API_PRIVATE_KEY_PATH=
BYBIT_ENV=testnet

# Safety caps
BYBIT_CAP_USD=500
BYBIT_CAP_USD_TOTAL_HOUR=2000
BYBIT_MAX_ORDERS_PER_HOUR=20

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
BYBIT_CLI_NO_UPDATE_CHECK=0

# =============================================================
# LLM
# =============================================================
LLM_PROVIDER=groq
LLM_MODEL=llama-3.1-8b-instant
LLM_FALLBACK_CHAIN=groq,openrouter,gemini
GROQ_API_KEY=gsk_...
OPENROUTER_API_KEY=
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2

# =============================================================
# Dynamic Watchlist
# =============================================================
WATCHLIST_CATEGORY=linear
WATCHLIST_TOP_N=15

# Liquidity floor (USDT 24h turnover)
# Scalping:  1000000  (1M)
# Default:  10000000  (10M)
# Safe:     50000000  (50M)
WATCHLIST_MIN_VOL_USD=10000000

# Execution quality gate
WATCHLIST_MAX_SPREAD_PCT=0.1

# Minimum 24h price move (filters dead markets)
WATCHLIST_MIN_CHANGE_PCT=0.5

# Always include regardless of score
WATCHLIST_ALWAYS_INCLUDE=BTCUSDT,ETHUSDT

# Cache TTL in seconds
# 30s  = good for loops < 5 min
# 60s  = good for loops 5-15 min
# 120s = good for loops 15-60 min
WATCHLIST_CACHE_TTL_SEC=30

# How many top opportunities to send LLM
SCAN_TOP_N=3

DEFAULT_SYMBOL=BTCUSDT
TREND_THRESH=0.003
VOL_THRESH_HIGH=0.02
VOL_THRESH_LOW=0.008

# Paid providers (optional)
TOGETHER_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=
